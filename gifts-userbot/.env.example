# Конфиг юзербот-сервиса покупки подарков. Скопируй в .env на сервере (НЕ коммить).
# Все три USERBOT_* — СЕКРЕТЫ (полный доступ к аккаунту-покупателю).

# С my.telegram.org (под аккаунтом-покупателем):
USERBOT_API_ID=
USERBOT_API_HASH=

# Строка сессии из gen_session.py (запускать локально):
USERBOT_SESSION=

# TON-кошелёк юзербота — флоат, которым выкупаем подарки на маркете. 24 слова.
USERBOT_TON_MNEMONIC=

# Маржа на обмен TON->подарок (0.15 = +15% к цене Portals). Доход дома.
GIFT_MARGIN=0.15

# Внутренний порт HTTP-API для Go-бэка.
PORT=8100
