# Copy to .env and fill in. Never commit .env.

# ── Core ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://predict:predict@localhost:55432/predict?sslmode=disable
PORT=8000
# Telegram bot token from @BotFather (validates Mini App initData + Stars payments).
TG_BOT_TOKEN=
# Allowed Mini App origin for CORS (your deployed web URL).
WEB_ORIGIN=https://app.example.com

# ── Local dev only (NEVER set in production) ─────────────────────────────
# Authenticate as this user id without Telegram, for local testing.
# DEV_USER_ID=1
# ALLOW_INSECURE_INITDATA=0

# ── Telegram webhook (Stars payments) ────────────────────────────────────
TG_WEBHOOK_URL=
TG_WEBHOOK_SECRET=

# ── Sign-up bonus (play money) ───────────────────────────────────────────
# Nano-TON granted on first /api/me (0 disables). 1 TON = 1_000_000_000.
SIGNUP_BONUS_NANO=0

# ── Polymarket ingest + resolver ─────────────────────────────────────────
POLY_INGEST_ENABLED=true
POLY_INGEST_LIMIT=120
POLY_INGEST_INTERVAL_SEC=300
POLY_RESOLVE_ENABLED=true
POLY_RESOLVE_INTERVAL_SEC=300

# ── TON deposits (on-chain watcher) ──────────────────────────────────────
TON_DEPOSIT_ENABLED=false
TON_DEPOSIT_ADDRESS=
TONCENTER_API_KEY=
TON_WATCH_INTERVAL_SEC=15

# ── TON withdrawals (hot-wallet sender) ──────────────────────────────────
# Set the mnemonic to enable automatic on-chain payouts. KEEP IT SECRET.
TON_WITHDRAW_ENABLED=false
TON_HOT_WALLET_MNEMONIC=
TON_WITHDRAW_INTERVAL_SEC=20

# ── Games (enable/disable; economics have sensible defaults in code) ──────
ROCKET_ENABLED=true
DICE_ENABLED=true
CASE_ENABLED=true
BASKET_ENABLED=true
